# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-token-for-server-mutations

# Optional: one-time seed (Kennedy Bay members). Use in request: Authorization: Bearer <value> or body { "secret": "<value>" }
# SEED_SECRET=your-secret
